import LeanProofs.Flux.Prelude
import LeanFixpoint
open Classical

namespace F



def Test01 := 
 ∀ (n₀ : Int),
  (0 ≤ n₀) ->
   (((n₀ % 2) = 0) ∧ (n₀ > 0)) ->
    (n₀ ≥ 0) ->
     ((((n₀ / 2) - 1) ≥ 0)) ∧
     (((0 ≤ ((n₀ / 2) - 1))) ∧
     ((((n₀ / 2) - 1) < n₀))
     ) ∧
     ((((n₀ - 1) ≥ 0)) ∧
     ((((n₀ / 2) ≤ (n₀ - 1))) ∧
     (((n₀ - 1) < n₀)) ∧
     (((((n₀ / 2) - 1) < (n₀ / 2)) ∨ ((n₀ - 1) < 0)))
     ) ∧
     ((((((n₀ / 2) - 1) - 0) + 1) ≥ 0) ->
      ((((n₀ - 1) - (n₀ / 2)) + 1) ≥ 0) ->
       ((((n₀ - 1) - (n₀ / 2)) + 1) = ((((n₀ / 2) - 1) - 0) + 1)))
     )
     
end F
